# ============================================================
# Hermeneutica — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values

# Database (PostgreSQL 16 + pgvector)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bible_research
DB_USER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_PASSWORD=postgres

# For Azure PostgreSQL (requires SSL)
# DATABASE_URL=postgresql://user:pass@server.postgres.database.azure.com:5432/bible_research
# DATABASE_SSL=true

# API Keys (for hermeneutics classification)
ANTHROPIC_API_KEY=your-key-here

# Web App — Contact Form (optional, uses Resend)
RESEND_API_KEY=re_your-key-here
CONTACT_EMAIL=your-email@example.com
